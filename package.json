{
  "name": "exojs-examples",
  "description": "Playground for ExoJS examples.",
  "version": "1.0.0",
  "license": "MIT",
  "author": "Dieter Giesler",
  "homepage": "https://exoridus.github.io/ExoJS-examples/",
  "repository": {
    "type": "git",
    "url": "git@github.com:Exoridus/ExoJS-examples.git"
  },
  "scripts": {
    "vendor:sync:exo": "node scripts/sync-exo-vendor.mjs",
    "vendor:sync:stats": "node scripts/sync-stats-vendor.mjs",
    "vendor:sync": "npm run vendor:sync:exo && npm run vendor:sync:stats",
    "assets:sync:input-prompts": "node scripts/sync-kenney-input-prompts.mjs",
    "dev": "npm run vendor:sync && cross-env NODE_ENV=development SASS_SILENCE_DEPRECATIONS=legacy-js-api rollup -cw",
    "build": "npm run vendor:sync && cross-env NODE_ENV=production SASS_SILENCE_DEPRECATIONS=legacy-js-api rollup -c",
    "test:dist": "npm run build && node --test tests/dist-open.smoke.test.mjs",
    "preview:dist": "npm run build && http-server dist -a 127.0.0.1 -p 4173 -c-1 -o /index.html",
    "deploy": "git subtree push --prefix dist origin gh-pages",
    "prettier": "prettier src/**/*.ts --config .prettierrc --write",
    "check-ts": "tsc --noEmit --pretty",
    "check-code": "eslint ./src/**/*.ts --fix",
    "check-lit": "lit-analyzer src --strict"
  },
  "main": "dist/examples.js",
  "browser": "dist/examples.js",
  "typings": "dist/examples.d.ts",
  "devDependencies": {
    "@adobe/lit-mobx": "0.0.4",
    "@rollup/plugin-commonjs": "^28.0.2",
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-node-resolve": "^16.0.1",
    "@rollup/plugin-replace": "^5.0.7",
    "@rollup/plugin-terser": "^0.4.4",
    "@rollup/plugin-typescript": "^12.1.2",
    "@types/dedent": "^0.7.0",
    "@types/node": "^22.13.10",
    "@typescript-eslint/eslint-plugin": "^3.6.0",
    "@typescript-eslint/parser": "^3.6.0",
    "autobind-decorator": "^2.4.0",
    "autoprefixer": "^10.4.21",
    "cross-env": "^10.1.0",
    "eslint": "^7.4.0",
    "eslint-config-prettier": "^6.11.0",
    "eslint-plugin-prettier": "^3.1.4",
    "http-server": "^14.1.1",
    "lit-analyzer": "^1.2.0",
    "lit-element": "^2.3.1",
    "lit-html": "^1.2.1",
    "mobx": "^5.15.4",
    "playwright": "^1.52.0",
    "prettier": "^2.0.5",
    "rollup": "^2.79.2",
    "rollup-plugin-copy": "^3.3.0",
    "rollup-plugin-delete": "^3.0.2",
    "rollup-plugin-dev": "^1.1.2",
    "rollup-plugin-progress": "^1.1.2",
    "rollup-plugin-styles": "^4.0.0",
    "sass": "1.78.0",
    "stats.js": "^0.17.0",
    "tslib": "^2.0.0",
    "typescript": "^5.8.2"
  },
  "dependencies": {
    "@codemirror/lang-javascript": "^6.2.4",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.36.3",
    "codemirror": "^6.0.2",
    "dedent": "^0.7.0"
  },
  "peerDependencies": {}
}
